# ─── Copy this file to .env and fill in your real values ─────────────────────
# Never commit .env to version control

# ── Global ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_64
JWT_EXPIRES_IN=15m

# ── PostgreSQL – User Service ─────────────────────────────────────────────────
POSTGRES_USER_DB=userdb
POSTGRES_USER_USER=user_svc
POSTGRES_USER_PASS=CHANGE_ME

# ── PostgreSQL – Product Service ──────────────────────────────────────────────
POSTGRES_PRODUCT_DB=productdb
POSTGRES_PRODUCT_USER=product_svc
POSTGRES_PRODUCT_PASS=CHANGE_ME

# ── PostgreSQL – Order Service ────────────────────────────────────────────────
POSTGRES_ORDER_DB=orderdb
POSTGRES_ORDER_USER=order_svc
POSTGRES_ORDER_PASS=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=rabbit_user
RABBITMQ_PASS=CHANGE_ME

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── SendGrid (email) ──────────────────────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.CHANGE_ME
FROM_EMAIL=noreply@yourstore.com

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACCHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+15551234567

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASS=CHANGE_ME
